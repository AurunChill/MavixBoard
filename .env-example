SIGNAL_SERVER_IP=http://localhost
# ADMIN_ID и ENROLLMENT_TOKEN сервер вшивает в preset.env при сборке tarball.
# По ним board сам регистрируется при первом запуске и дописывает сюда
# DRONE_ID/DRONE_TOKEN/DRONE_NAME — заранее их задавать не нужно.
ADMIN_ID=
ENROLLMENT_TOKEN=
DRONE_ID=
DRONE_TOKEN=
DRONE_NAME=
STUN_SERVER=stun://your-server:3478
TURN_SERVER=turn://user:password@your-server:3478
