SIGNAL_SERVER_IP=http://localhost
USER_ID=
# DRONE_ID and DRONE_TOKEN are baked into /etc/mavixboard/preset.env at
# .deb build time by the server. For dev runs without the .deb, leave
# both empty — the board will fall back to a locally-generated token
# stored at ~/.config/mavixboard/token and try to register on boot.
DRONE_ID=
DRONE_TOKEN=
STUN_SERVER=stun://your-server:3478
TURN_SERVER=turn://user:password@your-server:3478
